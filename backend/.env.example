# Select exactly one provider: openai, nvidia, or auto.
SCAVIBE_LLM_PROVIDER=openai
# Required only when SCAVIBE_LLM_PROVIDER=openai.
OPENAI_API_KEY=your_openai_project_key
# Required only when SCAVIBE_LLM_PROVIDER=nvidia.
# NVIDIA_API_KEY=your_nvidia_nim_key
# Optional in NVIDIA mode; default is nvidia/llama-3.3-nemotron-super-49b-v1.5.
# SCAVIBE_NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
# Auto mode tries OpenAI first for every request, then retries once with NVIDIA
# after an OpenAI gateway failure. It requires both provider keys.
# SCAVIBE_LLM_PROVIDER=auto
SCAVIBE_ALLOWED_ORIGINS=http://localhost:3000
GITHUB_TOKEN=ghp_...
BLOB_READ_WRITE_TOKEN=...
